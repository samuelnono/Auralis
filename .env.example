# Auralis environment variables.
# Copy to `.env` for local development:   cp .env.example .env
# `.env` is gitignored; never commit real secrets.

# ── Backend ───────────────────────────────────────────────────────────────────

# Anthropic API key used by the /chat endpoint. Get one at
# https://console.anthropic.com/. Without this the backend falls back to a
# static message and chat features are disabled.
ANTHROPIC_API_KEY=

# Comma-separated list of allowed CORS origins.
# Defaults to the Vite/CRA dev servers. In production (Fly.io), set this to
# the Vercel URL, e.g.  CORS_ORIGINS=https://auralis.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Per-IP rate limit on /chat (rolling window).
# Keeps the public demo cheap; tune up on a private deploy.
CHAT_RATE_LIMIT=10
CHAT_RATE_WINDOW_SEC=3600

# ── Frontend (Vite) ───────────────────────────────────────────────────────────

# Public URL of the backend API. In Vercel, set this in the project's
# Environment Variables (any environment — Production, Preview, Development).
# Vite inlines the value at build time, so changes require a redeploy.
VITE_API_URL=http://localhost:8000
